# ============================================================
# Python 自動產生的檔案（每台電腦不同，不需要上傳）
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================
# 打包 / 安裝產生的檔案
# ============================================================
*.egg-info/
*.egg
dist/
build/

# ============================================================
# 虛擬環境（每台電腦要自己建，不上傳）
# ============================================================
.venv/
venv/
env/

# ============================================================
# 環境變數 / 機密資訊（絕對不要上傳！）
# ============================================================
.env
.env.local
.env.production
*.secret
secrets.yaml
credentials.json

# ============================================================
# IDE / 編輯器設定（每個人不同，不需要共享）
# ============================================================
.vscode/
.idea/
.cursor/
*.swp
*.swo

# ============================================================
# 作業系統產生的檔案
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# 資料檔案（太大、會一直變，不適合放 Git）
# ============================================================
*.csv
*.xlsx
*.pkl
*.h5
*.parquet
data_cache/
cache/
